<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="IntroController"
            prefWidth="800" prefHeight="500">

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <Label text="Three Card Poker - Server" style="-fx-font-size:24px;"/>

            <GridPane hgap="10" vgap="10">
                <Label text="Port:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="portField" promptText="5555"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="IP Address" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="ipField" promptText="0.0.0.0"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button text="Start Server"
                        fx:id="startBtn"
                        onAction="#onStartServer"
                        GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                <Button text="Go to Server Logs"
                        onAction="#showServerLogsScene"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Label text="Start the server, then open the Server Logs screen."
                   wrapText="true"/>
        </VBox>
    </center>

</BorderPane>