<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ServerController"
            prefWidth="900" prefHeight="600">

    <top>
        <Label text="Three Card Poker - Server Control"
               style="-fx-font-size: 24px; -fx-padding: 20 0 20 0;"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Server Log:" style="-fx-font-size: 18px;"/>
            <ListView fx:id="logList" prefHeight="400"/>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <VBox spacing="5">
                <Label text="IP Address:"/>
                <TextField fx:id="ipField" promptText="0.0.0.0" prefWidth="150"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Port:"/>
                <TextField fx:id="portField" promptText="5555" prefWidth="100"/>
            </VBox>

            <Button fx:id="startButton"
                    text="Start Server"
                    onAction="#startServer"
                    style="-fx-font-size: 16px; -fx-background-color: #7ff67f;"/>

            <Button fx:id="stopButton"
                    text="Stop Server"
                    onAction="#stopServer"
                    disable="true"
                    style="-fx-font-size: 16px; -fx-background-color: #f08080;"/>

        </HBox>
    </bottom>

</BorderPane>

